# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/luxe_launchpad"

# Auth
AUTH_SECRET="your-secret-auth-secret"
ADMIN_EMAIL="admin@gmail.com"
ADMIN_PASSWORD="12345678"


# GCP Cloud Storage (keyfile only)
GCP_BUCKET_NAME=your-bucket-name

# Option A: path to service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json

# Option B: key as JSON string in env (e.g. for serverless)
# GCP_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...",...}'

# Optional, if not set in key file
# GCP_PROJECT_ID=your-gcp-project-id
