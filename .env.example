# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/luxe_launchpad"

# Auth
AUTH_SECRET="your-secret-auth-secret"
ADMIN_EMAIL="admin@gmail.com"
ADMIN_PASSWORD="12345678"


# GCP Cloud Storage
GCP_BUCKET_NAME=your-bucket-name

# Option A: Service account JSON key (local dev, Vercel with key)
# GCP_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Option B: OIDC / Workload Identity (Vercel – no keys; use GCP_* or GOOGLE_* names)
# GCP_PROJECT_ID / GOOGLE_PROJECT_ID
# GCP_PROJECT_NUMBER / GOOGLE_PROJECT_NUMBER
# GCP_WORKLOAD_IDENTITY_POOL_ID / GOOGLE_WORKLOAD_IDENTITY_POOL
# GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID / GOOGLE_WORKLOAD_IDENTITY_PROVIDER
# GCP_SERVICE_ACCOUNT_EMAIL / GOOGLE_SERVICE_ACCOUNT
